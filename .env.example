# ==========================================================
# IBM watsonx.ai credentials — copy this file to ".env" and
# fill in your own values. NEVER commit the real ".env" file.
# ==========================================================

# IBM Cloud API Key (IAM)  -> https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai Project ID -> found in your watsonx.ai project's "Manage" tab
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Regional watsonx.ai base URL (choose the one matching your region)
# us-south : https://us-south.ml.cloud.ibm.com
# eu-de    : https://eu-de.ml.cloud.ibm.com
# eu-gb    : https://eu-gb.ml.cloud.ibm.com
# jp-tok   : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite (or any other) foundation model deployed on watsonx.ai
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# watsonx.ai REST API version (date-based, keep updated periodically)
WATSONX_API_VERSION=2024-05-01

# App environment: development | production
APP_ENV=development

# ==========================================================
# Google Sheets backend — used to store user registrations
# ("LearnMate AI Users Data") and roadmap-form responses
# ("LearnMate AI Users Responses").
#
# Setup:
#   1. Create a Google Cloud project -> enable "Google Sheets API"
#      and "Google Drive API".
#   2. Create a Service Account -> generate a JSON key.
#   3. Share your target Google Sheets (or leave blank — the app
#      will auto-create them under the service account) with the
#      service account's email address as an Editor.
#   4. EITHER set GOOGLE_SERVICE_ACCOUNT_FILE to a local path,
#      OR paste the full JSON key content into
#      GOOGLE_SERVICE_ACCOUNT_JSON (recommended for Streamlit
#      Community Cloud secrets, which can't upload files).
#
# If neither is set, the app automatically falls back to local
# CSV storage under ./data/ so it still runs end-to-end for demos.
# ==========================================================
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_USERS_SHEET_NAME=LearnMate AI Users Data
GOOGLE_RESPONSES_SHEET_NAME=LearnMate AI Users Responses

# ==========================================================
# IBM watsonx Orchestrate — powers the floating "AI Mentor"
# chatbot widget. If left blank, the widget falls back to a
# built-in rule-based mentor grounded in the student's own
# roadmap data, so the app still works without this configured.
# ==========================================================
WATSONX_ORCHESTRATE_EMBED_URL=
WATSONX_ORCHESTRATE_AGENT_ID=
